    dates: '1724–1804',
    descriptor: 'Aesthetic Judgment & the Sublime',
    quote: 'The beautiful is that which pleases universally without a concept.',
    keyIdeas: [
      '"This is beautiful" is subjective yet claims universal assent from others.',
      'Beauty gives disinterested pleasure — we appreciate it without desiring it.',
      'The sublime differs: overwhelming power defeats imagination but reveals moral reason.',
      'Kant\'s framework became Romanticism\'s defining philosophical foundation.',
    ],
  },
  {
    name: 'Georg Hegel',
    dates: '1770–1831',
    descriptor: 'Art as Absolute Spirit & the End of Art',
    quote: 'Art is the sensuous shining of the Idea.',
    keyIdeas: [
      'Art, religion, and philosophy are three forms through which Absolute Spirit knows itself.',
      'History of art: Symbolic (Egyptian) → Classical (Greek) → Romantic (Christian).',
      'Greek art achieved the perfect balance of form and spiritual content.',
      'Hegel declared the "end of art" — its supersession by philosophy, not its death.',
    ],
  },
  {
    name: 'Friedrich Nietzsche',
    dates: '1844–1900',
    descriptor: 'Apollo, Dionysus & Life-Affirming Art',
    quote: 'We have art in order not to die of the truth.',
    keyIdeas: [
      'Greek art arose from tension: Apollonian (form, clarity) vs Dionysian (ecstasy, dissolution).',
      'Great art needs both: form shapes energy; energy animates form.',
      'Art is the supreme life-affirming force — it beautifies, not mirrors, existence.',
      '"The Birth of Tragedy" (1872) profoundly influenced Wagner and 20th-century aesthetics.',
    ],
  },
  {
    name: 'Arthur Schopenhauer',
    dates: '1788–1860',
    descriptor: 'Art as Liberation from the Will',
    quote: 'Music expresses that which cannot be said and on which it is impossible to be silent.',
    keyIdeas: [
      'Art offers temporary liberation from the suffering-causing Will underlying existence.',
      'In contemplating great art, we become pure knowing subjects — freed from desire.',
      'Music stands apart: it directly expresses the Will itself, the innermost nature of reality.',
      'His aesthetics profoundly influenced Wagner, Nietzsche, Proust, and Thomas Mann.',
    ],
  },
  {
    name: 'Walter Benjamin',
    dates: '1892–1940',
    descriptor: 'Aura, Reproduction & the Politics of Art',
    quote: 'That which withers in the age of mechanical reproduction is the aura of the work of art.',
    keyIdeas: [
      'Photography and film shatter art\'s "aura" — its authentic presence in time and place.',
      'Mechanical reproduction democratizes culture but enables fascism\'s aestheticization of politics.',
      '"The Work of Art in the Age of Mechanical Reproduction" (1935) remains urgently relevant.',
      'His concept of aura frames every debate about authenticity and digital reproduction today.',
    ],
  },
  {
    name: 'John Dewey',
    dates: '1859–1952',
    descriptor: 'Art as Experience & Democratic Aesthetics',
    quote: 'Art is the living and concrete proof that man is capable of restoring the union of sense, need, impulse and action.',
    keyIdeas: [
      'Museum culture severs art from the living experience that generated it.',
      'Aesthetic experience is the heightened form of any meaningful, fulfilling activity.',
      'Great art grows from and returns to the fabric of ordinary life.',
      'Dewey\'s pragmatist aesthetics shaped democratic education and participatory art.',
    ],
  },
  {
    name: 'Simone de Beauvoir',
    dates: '1908–1986',
    descriptor: 'Art, Freedom & the Gendered Gaze',
    quote: 'The work of art is not a copy of reality but a reality of its own.',
    keyIdeas: [
      'Art has historically represented women as passive objects of the male gaze.',
      'Great art is a project of freedom — the artist transcends given conditions.',
      'Art created from bad faith merely reflects, rather than transforms, oppressive structures.',
      '"The Second Sex" (1949) made the gendered politics of representation unavoidable.',
    ],
  },
  {
    name: 'Martin Heidegger',
    dates: '1889–1976',
    descriptor: 'Art as the Setting-Itself-to-Work of Truth',
    quote: 'Art is the setting-itself-to-work of truth.',
    keyIdeas: [
      'Great art does not represent the world — it opens up a world.',
      'Van Gogh\'s shoes painting reveals the whole world of peasant labour and earth.',
      'Works create a strife between World (human meaning) and Earth (material resistance).',
      'Architecture and poetry are the most fundamental arts: they found human dwelling.',
    ],
  },
];

const quizQuestions = [
  { category: 'Techniques', q: 'Which technique did Leonardo da Vinci invent to blend oil glazes so gradually that contours dissolve into smoky haze?', options: ['Chiaroscuro', 'Sfumato', 'Impasto', 'Encaustic'], answer: 1 },
  { category: 'Baroque', q: 'Which Baroque painter revolutionized art with tenebrism — extreme darkness pierced by a single dramatic spotlight?', options: ['Peter Paul Rubens', 'Johannes Vermeer', 'Caravaggio', 'Rembrandt'], answer: 2 },
  { category: 'Impressionism', q: 'The Impressionist movement got its name (mockingly) from which painting?', options: ['Water Lilies', 'The Gleaners', 'Impression, Sunrise', 'The Dance'], answer: 2 },
  { category: 'Philosophy', q: 'Which philosopher argued that art is "twice removed from truth" — a copy of a copy of eternal Forms?', options: ['Aristotle', 'Immanuel Kant', 'Plato', 'Hegel'], answer: 2 },
  { category: 'Post-Impressionism', q: 'Pointillism — tiny dots of pure unmixed colour that blend in the eye — was developed by which artist?', options: ['Van Gogh', 'Paul Gauguin', 'Paul Cézanne', 'Georges Seurat'], answer: 3 },
  { category: 'Gallery', q: '"The Starry Night" was painted while Van Gogh was staying at which location?', options: ['A Paris studio', 'Amsterdam lodgings', 'An asylum in Saint-Rémy-de-Provence', 'A beach house in Arles'], answer: 2 },
  { category: 'Techniques', q: 'Buon fresco permanently bonds pigment by painting into what material while it is still wet?', options: ['Egg yolk', 'Beeswax', 'Linseed oil', 'Lime plaster'], answer: 3 },
  { category: 'Cubism', q: 'Which two artists jointly invented Cubism between 1907 and 1914?', options: ['Matisse & Derain', 'Dalí & Miró', 'Picasso & Braque', 'Kandinsky & Klee'], answer: 2 },
  { category: 'Philosophy', q: 'Which thinker argued that photography and film destroy art\'s unique "aura" — its authentic singular presence?', options: ['Martin Heidegger', 'John Dewey', 'Walter Benjamin', 'Theodor Adorno'], answer: 2 },
  { category: 'Techniques', q: 'The Fayum mummy portraits were made using which technique that uses heated beeswax mixed with pigment?', options: ['Fresco', 'Tempera', 'Oil paint', 'Encaustic'], answer: 3 },
  { category: 'Gallery', q: 'Vermeer\'s "Girl with a Pearl Earring" is classified in Dutch painting as what type of work?', options: ['History painting', 'Vanitas', 'Tronie (character study)', 'Triptych'], answer: 2 },
  { category: 'Philosophy', q: 'Nietzsche described great art as arising from tension between the ordered Apollonian drive and which opposing force?', options: ['The Socratic drive', 'The Dionysian drive', 'The Platonic drive', 'The Kantian sublime'], answer: 1 },
  { category: 'Renaissance', q: 'Who painted the Sistine Chapel ceiling, working in sections of wet plaster over four years (1508–1512)?', options: ['Leonardo da Vinci', 'Raphael', 'Botticelli', 'Michelangelo'], answer: 3 },
  { category: 'Gallery', q: 'Raphael\'s "School of Athens" places which two philosophers at the exact centre of the composition?', options: ['Socrates & Plato', 'Aristotle & Socrates', 'Plato & Aristotle', 'Hegel & Kant'], answer: 2 },
  { category: 'Gallery', q: '"Las Meninas" (1656), one of art history\'s most analyzed paintings, was created by which Spanish master?', options: ['Francisco Goya', 'El Greco', 'Bartolomé Murillo', 'Diego Velázquez'], answer: 3 },
  { category: 'Philosophy', q: 'Kant described aesthetic judgment as subjective yet doing what — which makes it unique?', options: ['Always relative to culture', 'Claiming universal assent', 'Rooted purely in reason', 'Dependent on moral virtue'], answer: 1 },
  { category: 'Gallery', q: 'The Great Wave off Kanagawa was created by which Japanese master?', options: ['Hiroshige', 'Utamaro', 'Hokusai', 'Kuniyoshi'], answer: 2 },
  { category: 'Fauvism', q: 'Which short-lived movement (1905–08) applied pure unmixed colour straight from the tube, independent of visual reality?', options: ['Cubism', 'Realism', 'Fauvism', 'Symbolism'], answer: 2 },
  { category: 'Gallery', q: 'In van Eyck\'s Arnolfini Portrait (1434), what does the convex mirror on the back wall show?', options: ['The subjects from behind', 'Two additional witnesses reflected in the room', 'An open window to a garden', 'A religious altarpiece'], answer: 1 },
  { category: 'Techniques', q: 'Impasto — paint applied so thickly it leaves a sculptural surface — is most famous in whose swirling skies?', options: ['Vermeer', 'Raphael', 'Van Gogh', 'Botticelli'], answer: 2 },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Artsy · Learn Art History</title>
  </head>
  <body>
    <div class="app-shell">

      <!-- ── HERO ──────────────────────────────────────────────────── -->
      <header class="hero-panel">
        <div class="hero-text">
          <p class="label">Artsy</p>
          <h1>Explore art history through vivid flashcards.</h1>
          <p class="intro">Journey through eras, styles &amp; techniques — then step into the Gallery, meet the Philosophers, or test yourself with the Quiz.</p>
        </div>
        <div class="hero-badge">Museum-ready learning interface</div>
      </header>

      <!-- ── MAIN NAVIGATION ────────────────────────────────────────── -->
      <nav class="main-nav" id="mainNav">
        <button class="main-tab active" data-view="art-history" type="button">Art History</button>
        <button class="main-tab" data-view="gallery"     type="button">Gallery</button>
        <button class="main-tab" data-view="philosophers" type="button">Philosophers</button>
        <button class="main-tab" data-view="quiz"        type="button">Quiz</button>
      </nav>

      <!-- ── VIEW: ART HISTORY ─────────────────────────────────────── -->
      <div id="view-art-history" class="view">
        <section class="controls">
          <p class="section-title">Choose a category</p>
          <div class="pill-row" id="categoryRow">
            {artSubcats.map((item) => (
              <button class="pill" data-category={item.id} type="button">{item.label}</button>
            ))}
          </div>
        </section>

        <section class="card-grid" id="artCardGrid">
          {artCards.map((card, index) => (
            <article class="flashcard" data-category={card.category} data-index={index}>
              <div class="flashcard-inner">
                <div class="flashcard-face flashcard-front">
                  <div class="image-frame">
                    <img src={card.image} alt={card.title} loading="lazy" />
                  </div>
                  <div class="card-copy">
                    <p class="eyebrow">{card.subtitle}</p>
                    <h2>{card.title}</h2>
                    <p class="flip-cue">Click to flip ↩</p>
                  </div>
                </div>
                <div class="flashcard-face flashcard-back art-back">
                  <p class="back-label">About this {card.category === 'eras' ? 'era' : card.category === 'styles' ? 'style' : 'technique'}</p>
                  <p class="back-summary">{card.summary}</p>
                  <div class="artists-row">
                    {card.artists.map((a) => <span class="artist-chip">{a}</span>)}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <!-- ── VIEW: GALLERY ─────────────────────────────────────────── -->
      <div id="view-gallery" class="view hidden">
        <div class="view-header">
          <h2 class="view-title">Gallery</h2>
          <p class="view-intro">Ten landmark works from art history. Click any painting to reveal its story.</p>
        </div>

        <section class="card-grid gallery-grid">
          {artworks.map((work) => (
            <article class="flashcard artwork-card">
              <div class="flashcard-inner">
                <div class="flashcard-face flashcard-front">
                  <div class="image-frame artwork-frame">
                    <img src={work.image} alt={work.title} loading="lazy" />
                    <div class="image-overlay">
                      <p class="overlay-artist">{work.artist}</p>
                      <p class="overlay-year">{work.year}</p>
                    </div>
                  </div>
                  <div class="card-copy gallery-copy">
                    <h2>{work.title}</h2>
                    <p class="tagline">{work.tagline}</p>
                    <p class="flip-cue">Click to read more ↩</p>
                  </div>
                </div>
                <div class="flashcard-face flashcard-back artwork-back">
                  <div class="artwork-meta">
                    <span class="meta-tag">{work.medium}</span>
                    <span class="meta-tag">{work.location}</span>
                  </div>
                  <p class="back-label">{work.title}</p>
                  <p class="back-summary">{work.description}</p>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <!-- ── VIEW: PHILOSOPHERS ────────────────────────────────────── -->
      <div id="view-philosophers" class="view hidden">
        <div class="view-header">
          <h2 class="view-title">Philosophers</h2>
          <p class="view-intro">Ten thinkers who shaped how we understand art, beauty, and meaning. Click a card to reveal their key ideas.</p>
        </div>

        <section class="card-grid philosophers-grid">
          {philosophers.map((p, i) => (
            <article class="flashcard philosopher-card" data-index={i}>
              <div class="flashcard-inner">
                <div class="flashcard-face flashcard-front philosopher-front">
                  <div class="phil-number">{String(i + 1).padStart(2, '0')}</div>
                  <div class="phil-identity">
                    <h2 class="phil-name">{p.name}</h2>
                    <p class="phil-dates">{p.dates}</p>
                    <p class="phil-descriptor">{p.descriptor}</p>
                  </div>
                  <p class="flip-hint">Tap to reveal key ideas ↩</p>
                </div>
                <div class="flashcard-face flashcard-back philosopher-back">
                  <blockquote class="phil-quote">"{p.quote}"</blockquote>
                  <ul class="phil-ideas">
                    {p.keyIdeas.map((idea) => <li>{idea}</li>)}
                  </ul>
                  <p class="phil-name-watermark">{p.name}</p>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <!-- ── VIEW: QUIZ ─────────────────────────────────────────────── -->
      <div id="view-quiz" class="view hidden">
        <div class="view-header">
          <h2 class="view-title">Quiz</h2>
          <p class="view-intro">20 questions drawn from every section — eras, styles, techniques, gallery, and philosophy.</p>
        </div>

        <div class="quiz-shell" id="quizShell">
          <div class="quiz-start" id="quizStart">
            <div class="quiz-start-icon">✦</div>
            <h3 class="quiz-start-title">Test your knowledge</h3>
            <p class="quiz-start-body">20 multiple-choice questions on art history, gallery works, painting techniques, and the philosophers who shaped how we think about beauty.</p>
            <button class="quiz-begin-btn" id="quizBeginBtn" type="button">Begin Quiz</button>
          </div>

          <div class="quiz-question" id="quizQuestion" style="display:none">
            <div class="quiz-header">
              <span class="quiz-counter" id="quizCounter">Question 1 of 20</span>
              <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="quizFill"></div></div>
              <span class="quiz-score-live" id="quizScoreLive">Score: 0</span>
            </div>
            <div class="quiz-body">
              <p class="quiz-category-tag" id="quizCategoryTag"></p>
              <h3 class="quiz-question-text" id="quizQuestionText"></h3>
              <div class="quiz-options" id="quizOptions"></div>
            </div>
          </div>

          <div class="quiz-results" id="quizResults" style="display:none">
            <div class="quiz-results-score" id="quizResultsScore"></div>
            <h3 class="quiz-results-title" id="quizResultsTitle"></h3>
            <p class="quiz-results-body" id="quizResultsBody"></p>
            <div class="quiz-breakdown" id="quizBreakdown"></div>
            <button class="quiz-begin-btn" id="quizRestartBtn" type="button" style="margin-top:1rem">Try Again</button>
          </div>
        </div>
      </div>

    </div><!-- end app-shell -->

    <script type="module">
      // ── Tab switching ─────────────────────────────────────────────
      const mainNav  = document.getElementById('mainNav');
      const views    = document.querySelectorAll('.view');
      const mainTabs = mainNav.querySelectorAll('.main-tab');

      mainNav.addEventListener('click', (e) => {
        const btn = e.target.closest('.main-tab[data-view]');
        if (!btn) return;
        const target = btn.dataset.view;
        mainTabs.forEach((t) => t.classList.toggle('active', t.dataset.view === target));
        views.forEach((v) => v.classList.toggle('hidden', v.id !== `view-${target}`));
      });

      // ── Art History sub-tabs ──────────────────────────────────────
      const categoryRow = document.getElementById('categoryRow');
      const artCardGrid = document.getElementById('artCardGrid');
      const artCards    = Array.from(artCardGrid.querySelectorAll('.flashcard'));
      const catBtns     = Array.from(categoryRow.querySelectorAll('button'));
      let activeCategory = 'eras';

      const updateCategory = (cat) => {
        activeCategory = cat;
        catBtns.forEach((b) => b.classList.toggle('active', b.dataset.category === cat));
        artCards.forEach((c) => c.classList.toggle('hidden', c.dataset.category !== cat));
      };

      categoryRow.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-category]');
        if (btn) updateCategory(btn.dataset.category);
      });

      updateCategory(activeCategory);

      // ── Card flip ─────────────────────────────────────────────────
      document.addEventListener('click', (e) => {
        const card = e.target.closest('.flashcard');
        if (!card) return;
        // Don't flip if clicking a quiz option button
        if (e.target.closest('.quiz-option, .quiz-begin-btn')) return;
        card.classList.toggle('flipped');
      });

      // ── Quiz ──────────────────────────────────────────────────────
      const QUESTIONS = JSON.parse(document.getElementById('quizData').textContent);
      let current = 0, score = 0, answered = false;

      const elStart     = document.getElementById('quizStart');
      const elQuestion  = document.getElementById('quizQuestion');
      const elResults   = document.getElementById('quizResults');
      const elCounter   = document.getElementById('quizCounter');
      const elFill      = document.getElementById('quizFill');
      const elScoreLive = document.getElementById('quizScoreLive');
      const elCatTag    = document.getElementById('quizCategoryTag');
      const elQText     = document.getElementById('quizQuestionText');
      const elOptions   = document.getElementById('quizOptions');

      function showQuestion() {
        answered = false;
        const q = QUESTIONS[current];
        elCounter.textContent   = `Question ${current + 1} of ${QUESTIONS.length}`;
        elFill.style.width      = `${(current / QUESTIONS.length) * 100}%`;
        elScoreLive.textContent = `Score: ${score}`;
        elCatTag.textContent    = q.category;
        elQText.textContent     = q.q;
        elOptions.innerHTML     = '';
        q.options.forEach((opt, i) => {
          const btn = document.createElement('button');
          btn.className   = 'quiz-option';
          btn.textContent = opt;
          btn.type        = 'button';
          btn.addEventListener('click', () => selectAnswer(i));
          elOptions.appendChild(btn);
        });
      }

      function selectAnswer(i) {
        if (answered) return;
        answered = true;
        const q    = QUESTIONS[current];
        const btns = elOptions.querySelectorAll('.quiz-option');
        btns.forEach((b) => b.disabled = true);
        if (i === q.answer) { score++; btns[i].classList.add('correct'); }
        else { btns[i].classList.add('wrong'); btns[q.answer].classList.add('correct'); }
        elScoreLive.textContent = `Score: ${score}`;
        setTimeout(() => { current < QUESTIONS.length - 1 ? (current++, showQuestion()) : showResults(); }, 1100);
      }

      function showResults() {
        elFill.style.width      = '100%';
        elQuestion.style.display = 'none';
        elResults.style.display  = 'flex';
        const pct   = Math.round((score / QUESTIONS.length) * 100);
        const tier  = pct < 40 ? 0 : pct < 60 ? 1 : pct < 75 ? 2 : pct < 95 ? 3 : 4;
        const titles = ['Keep exploring!', 'Good start!', 'Well done!', 'Impressive!', 'Masterpiece!'];
        const bodies = [
          'Wander through the flashcards and gallery — the answers are all there.',
          'A solid foundation. Review the Eras and Techniques tabs to sharpen up.',
          'You know your art history. A few more rounds and you\'ll be unstoppable.',
          'Exceptional knowledge across eras, styles, and philosophy.',
          'A perfect score — the curators would be proud.',
        ];
        document.getElementById('quizResultsScore').textContent = `${score} / ${QUESTIONS.length}`;
        document.getElementById('quizResultsTitle').textContent = titles[tier];
        document.getElementById('quizResultsBody').textContent  = bodies[tier];
        const bd = document.getElementById('quizBreakdown');
        bd.innerHTML = '';
        [['Score', `${pct}%`], ['Correct', score], ['Incorrect', QUESTIONS.length - score]].forEach(([l, v]) => {
          const chip = document.createElement('span');
          chip.className   = 'quiz-breakdown-chip';
          chip.textContent = `${l}: ${v}`;
          bd.appendChild(chip);
        });
      }

      function startQuiz() {
        current = 0; score = 0;
        elStart.style.display    = 'none';
        elResults.style.display  = 'none';
        elQuestion.style.display = 'flex';
        showQuestion();
      }

      document.getElementById('quizBeginBtn').addEventListener('click', startQuiz);
      document.getElementById('quizRestartBtn').addEventListener('click', startQuiz);
    </script>

    <script id="quizData" type="application/json" set:html={JSON.stringify(quizQuestions)}></script>
  </body>
</html>
