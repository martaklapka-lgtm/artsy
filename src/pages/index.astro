---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Artsy · Learn Art History</title>
  </head>
  <body>
    <div class="app-shell">

      <!-- ── HERO ───────────────────────────────────────────────────── -->
      <header class="hero-panel">
        <div>
          <p class="label">Artsy</p>
          <h1>Explore art history through vivid flashcards.</h1>
          <p class="intro">Journey through eras, styles, and techniques — then step into the Gallery or meet the philosophers who shaped how we think about beauty.</p>
        </div>
        <div class="hero-badge">Museum-ready learning interface</div>
      </header>

      <!-- ── MAIN NAVIGATION ───────────────────────────────────────── -->
      <nav class="main-nav" id="mainNav">
        <button class="main-tab active" data-view="art-history" type="button">Art History</button>
        <button class="main-tab" data-view="gallery" type="button">Gallery</button>
        <button class="main-tab" data-view="philosophers" type="button">Philosophers</button>
        <button class="main-tab" data-view="quiz" type="button">Quiz</button>
      </nav>

      <!-- ── VIEW: ART HISTORY ─────────────────────────────────────── -->
      <div id="view-art-history" class="view">
        <section class="controls">
          <p class="section-title">Choose a category</p>
          <div class="pill-row" id="categoryRow">
            {artSubcats.map((item) => (
              <button class="pill" data-category={item.id} type="button">{item.label}</button>
            ))}
          </div>
        </section>

        <section class="card-grid" id="artCardGrid">
          {artCards.map((card, index) => (
            <article class="flashcard" data-category={card.category} data-index={index}>
              <div class="flashcard-inner">
                <div class="flashcard-face flashcard-front">
                  <div class="image-frame">
                    <img src={card.image} alt={card.title} loading="lazy" />
                  </div>
                  <div class="card-copy">
                    <p class="eyebrow">{card.subtitle}</p>
                    <h2>{card.title}</h2>
                    <p class="flip-cue">Click to flip</p>
                  </div>
                </div>
                <div class="flashcard-face flashcard-back">
                  <p class="back-label">Key artists &amp; context</p>
                  <p>{card.fact}</p>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <!-- ── VIEW: GALLERY ─────────────────────────────────────────── -->
      <div id="view-gallery" class="view hidden">
        <div class="view-header">
          <h2 class="view-title">Gallery</h2>
          <p class="view-intro">Ten landmark works from Western and global art history. Click any painting to reveal its story.</p>
        </div>

        <section class="card-grid">
          {artworks.map((work) => (
            <article class="flashcard artwork-card">
              <div class="flashcard-inner">
                <div class="flashcard-face flashcard-front">
                  <div class="image-frame artwork-frame">
                    <img src={work.image} alt={work.title} loading="lazy" />
                  </div>
                  <div class="card-copy">
                    <p class="eyebrow">{work.artist} · {work.year}</p>
                    <h2>{work.title}</h2>
                  </div>
                </div>
                <div class="flashcard-face flashcard-back artwork-back">
                  <div class="artwork-meta">
                    <span class="meta-tag">{work.medium}</span>
                    <span class="meta-tag">{work.location}</span>
                  </div>
                  <p class="back-label">{work.title}</p>
                  <p>{work.description}</p>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <!-- ── VIEW: PHILOSOPHERS ────────────────────────────────────── -->
      <div id="view-philosophers" class="view hidden">
        <div class="view-header">
          <h2 class="view-title">Philosophers</h2>
          <p class="view-intro">Ten thinkers who shaped how we understand art, beauty, and meaning. Click a card to reveal their key ideas.</p>
        </div>

        <section class="card-grid philosophers-grid">
          {philosophers.map((p, i) => (
            <article class="flashcard philosopher-card" data-index={i}>
              <div class="flashcard-inner">
                <div class="flashcard-face flashcard-front philosopher-front">
                  <div class="phil-number">{String(i + 1).padStart(2, '0')}</div>
                  <div class="phil-identity">
                    <h2 class="phil-name">{p.name}</h2>
                    <p class="phil-dates">{p.dates}</p>
                    <p class="phil-descriptor">{p.descriptor}</p>
                  </div>
                  <p class="flip-hint">Tap to reveal key ideas</p>
                </div>
                <div class="flashcard-face flashcard-back philosopher-back">
                  <blockquote class="phil-quote">"{p.quote}"</blockquote>
                  <div class="phil-divider"></div>
                  <p class="phil-thought">{p.thought}</p>
                  <p class="phil-name-watermark">{p.name}</p>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <!-- ── VIEW: QUIZ ───────────────────────────────────────────── -->
      <div id="view-quiz" class="view hidden">
        <div class="view-header">
          <h2 class="view-title">Quiz</h2>
          <p class="view-intro">20 questions drawn from every section of this site — eras, styles, techniques, gallery, and philosophy.</p>
        </div>

        <div class="quiz-shell" id="quizShell">

          <!-- Start screen -->
          <div class="quiz-start" id="quizStart">
            <div class="quiz-start-icon">✦</div>
            <h3 class="quiz-start-title">Test your knowledge</h3>
            <p class="quiz-start-body">20 multiple-choice questions on art history, gallery works, painting techniques, and the philosophers who shaped how we think about beauty.</p>
            <button class="quiz-begin-btn" id="quizBeginBtn" type="button">Begin Quiz</button>
          </div>

          <!-- Question screen -->
          <div class="quiz-question" id="quizQuestion" style="display:none">
            <div class="quiz-header">
              <span class="quiz-counter" id="quizCounter">Question 1 of 20</span>
              <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="quizFill"></div></div>
              <span class="quiz-score-live" id="quizScoreLive">Score: 0</span>
            </div>
            <div class="quiz-body">
              <p class="quiz-category-tag" id="quizCategoryTag">Category</p>
              <h3 class="quiz-question-text" id="quizQuestionText"></h3>
              <div class="quiz-options" id="quizOptions"></div>
            </div>
          </div>

          <!-- Results screen -->
          <div class="quiz-results" id="quizResults" style="display:none">
            <div class="quiz-results-score" id="quizResultsScore"></div>
            <h3 class="quiz-results-title" id="quizResultsTitle"></h3>
            <p class="quiz-results-body" id="quizResultsBody"></p>
            <div class="quiz-breakdown" id="quizBreakdown"></div>
            <button class="quiz-begin-btn" id="quizRestartBtn" type="button" style="margin-top:1rem">Try Again</button>
          </div>

        </div>
      </div>

    </div><!-- end app-shell -->

    <script type="module">
      // ── Main tab switching ──────────────────────────────────────────
      const mainNav = document.getElementById('mainNav');
      const views = document.querySelectorAll('.view');
      const mainTabs = mainNav.querySelectorAll('.main-tab');

      mainNav.addEventListener('click', (e) => {
        const btn = e.target.closest('.main-tab[data-view]');
        if (!btn) return;
        const target = btn.dataset.view;
        mainTabs.forEach((t) => t.classList.toggle('active', t.dataset.view === target));
        views.forEach((v) => v.classList.toggle('hidden', v.id !== `view-${target}`));
      });

      // ── Art History sub-category tabs ───────────────────────────────
      const categoryRow = document.getElementById('categoryRow');
      const artCardGrid = document.getElementById('artCardGrid');
      const artCards = Array.from(artCardGrid.querySelectorAll('.flashcard'));
      const catBtns = Array.from(categoryRow.querySelectorAll('button'));
      let activeCategory = 'eras';

      const updateCategory = (cat) => {
        activeCategory = cat;
        catBtns.forEach((b) => b.classList.toggle('active', b.dataset.category === cat));
        artCards.forEach((c) => c.classList.toggle('hidden', c.dataset.category !== cat));
      };

      categoryRow.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-category]');
        if (btn) updateCategory(btn.dataset.category);
      });

      updateCategory(activeCategory);

      // ── Card flip (all sections) ────────────────────────────────────
      document.addEventListener('click', (e) => {
        const card = e.target.closest('.flashcard');
        if (!card) return;
        card.classList.toggle('flipped');
      });

      // ── Quiz ────────────────────────────────────────────────────────
      const QUESTIONS = JSON.parse(document.getElementById('quizData').textContent);

      let current = 0, score = 0, answered = false;

      const elStart    = document.getElementById('quizStart');
      const elQuestion = document.getElementById('quizQuestion');
      const elResults  = document.getElementById('quizResults');
      const elCounter  = document.getElementById('quizCounter');
      const elFill     = document.getElementById('quizFill');
      const elScoreLive= document.getElementById('quizScoreLive');
      const elCatTag   = document.getElementById('quizCategoryTag');
      const elQText    = document.getElementById('quizQuestionText');
      const elOptions  = document.getElementById('quizOptions');

      function showQuestion() {
        answered = false;
        const q = QUESTIONS[current];
        elCounter.textContent  = `Question ${current + 1} of ${QUESTIONS.length}`;
        elFill.style.width     = `${(current / QUESTIONS.length) * 100}%`;
        elScoreLive.textContent= `Score: ${score}`;
        elCatTag.textContent   = q.category;
        elQText.textContent    = q.q;
        elOptions.innerHTML    = '';
        q.options.forEach((opt, i) => {
          const btn = document.createElement('button');
          btn.className = 'quiz-option';
          btn.textContent = opt;
          btn.type = 'button';
          btn.addEventListener('click', () => selectAnswer(i));
          elOptions.appendChild(btn);
        });
      }

      function selectAnswer(i) {
        if (answered) return;
        answered = true;
        const q = QUESTIONS[current];
        const btns = elOptions.querySelectorAll('.quiz-option');
        btns.forEach((b) => b.disabled = true);
        if (i === q.answer) {
          score++;
          btns[i].classList.add('correct');
        } else {
          btns[i].classList.add('wrong');
          btns[q.answer].classList.add('correct');
        }
        elScoreLive.textContent = `Score: ${score}`;
        setTimeout(() => {
          current++;
          if (current < QUESTIONS.length) {
            showQuestion();
          } else {
            showResults();
          }
        }, 1100);
      }

      function showResults() {
        elFill.style.width = '100%';
        elQuestion.style.display = 'none';
        elResults.style.display  = 'flex';
        const pct = Math.round((score / QUESTIONS.length) * 100);
        document.getElementById('quizResultsScore').textContent = `${score} / ${QUESTIONS.length}`;
        const titles = ['Keep exploring!', 'Good start!', 'Well done!', 'Impressive!', 'Masterpiece!'];
        const bodies = [
          'Wander through the flashcards and gallery — the answers are all there.',
          'A solid foundation. Review the Eras and Techniques tabs to sharpen up.',
          'You know your art history. A few more rounds and you\'ll be unstoppable.',
          'Exceptional knowledge across eras, styles, and philosophy.',
          'A perfect score — the curators would be proud.',
        ];
        const tier = pct < 40 ? 0 : pct < 60 ? 1 : pct < 75 ? 2 : pct < 95 ? 3 : 4;
        document.getElementById('quizResultsTitle').textContent = titles[tier];
        document.getElementById('quizResultsBody').textContent  = bodies[tier];
        const breakdown = document.getElementById('quizBreakdown');
        breakdown.innerHTML = '';
        [['Score', `${pct}%`], ['Correct', score], ['Incorrect', QUESTIONS.length - score]].forEach(([label, val]) => {
          const chip = document.createElement('span');
          chip.className = 'quiz-breakdown-chip';
          chip.textContent = `${label}: ${val}`;
          breakdown.appendChild(chip);
        });
      }

      function startQuiz() {
        current = 0; score = 0;
        elStart.style.display   = 'none';
        elResults.style.display = 'none';
        elQuestion.style.display= 'flex';
        showQuestion();
      }

      document.getElementById('quizBeginBtn').addEventListener('click', startQuiz);
      document.getElementById('quizRestartBtn').addEventListener('click', startQuiz);
    </script>

    <!-- Quiz data injected as JSON to avoid Astro template issues -->
    <script id="quizData" type="application/json" set:html={JSON.stringify(quizQuestions)}></script>
  </body>
</html>
