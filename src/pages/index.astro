---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Luma — Art & Science</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="header">
    <div class="header-inner">
      <div class="brand">
        <svg class="brand-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4" fill="currentColor" opacity=".9"/>
          <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.2" opacity=".4"/>
          <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width=".6" opacity=".15"/>
        </svg>
        <span class="brand-name">Luma</span>
      </div>

      <nav class="nav" role="navigation" aria-label="Main navigation">
        <button class="nav-tab active" data-view="cards" data-label-en="Art" data-label-pl="Sztuka">Art</button>
        <button class="nav-tab" data-view="science" data-label-en="Science" data-label-pl="Nauka">Science</button>
        <button class="nav-tab" data-view="vocab" data-label-en="Vocab" data-label-pl="Słownik">Vocab</button>
        <button class="nav-tab" data-view="quiz" data-label-en="Quiz" data-label-pl="Quiz">Quiz</button>
      </nav>

      <div class="header-actions">
        <div id="catFilters" class="cat-filters">
          <button class="chip active" data-cat="all">All</button>
          <button class="chip" data-cat="Eras">Eras</button>
          <button class="chip" data-cat="Styles">Styles</button>
          <button class="chip" data-cat="Techniques">Techniques</button>
          <button class="chip chip--fav" data-cat="favs">♡ Saved</button>
        </div>
        <button class="lang-btn" id="langBtn" aria-label="Switch language">PL</button>
      </div>
    </div>
    <div class="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progressRole">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </header>

  <main class="main">

    <!-- ART CARDS -->
    <div id="cardsView" class="view">
      <div class="deck-meta">
        <span id="progressText" class="meta-count"></span>
        <span id="categoryLabel" class="meta-cat"></span>
      </div>
      <div class="scene">
        <article class="card" id="flashcard" tabindex="0" role="button" aria-pressed="false">
          <div class="card-inner" id="cardInner">
            <div class="face face-front">
              <div class="card-img-wrap">
                <img id="cardImg" class="card-img" src="" alt="" loading="eager" />
                <span class="cat-badge" id="frontCatPill"></span>
                <button class="fav-btn" id="favBtn" aria-label="Save to favourites">♡</button>
                <div class="gal-nav" id="artGalNav">
                  <button class="gal-arrow" id="artGalPrev" aria-label="Previous image">&#8249;</button>
                  <div class="gal-dots" id="artGalDots"></div>
                  <button class="gal-arrow" id="artGalNext" aria-label="Next image">&#8250;</button>
                </div>
              </div>
              <div class="front-body">
                <p class="eyebrow" id="hintEyebrow">Wskazówka</p>
                <p class="hint-text" id="hintText"></p>
                <h2 class="card-title" id="cardTitle"></h2>
                <p class="flip-cue" id="flipCueFront">kliknij, by odkryć →</p>
              </div>
            </div>
            <div class="face face-back">
              <div class="back-top">
                <span class="back-badge" id="backCat"></span>
                <h2 class="back-title" id="backTitle"></h2>
                <p class="back-period" id="backPeriod"></p>
              </div>
              <div class="back-rule"></div>
              <div class="back-body">
                <div class="info-block">
                  <p class="info-label" id="artistsLabel">Kluczowi artyści</p>
                  <p class="info-value" id="backArtists"></p>
                </div>
                <div class="info-block">
                  <p class="info-label" id="philLabel">Filozofia wizualna</p>
                  <p class="info-value" id="backPhilosophy"></p>
                </div>
              </div>
              <div class="back-footer">
                <div class="tag-row" id="keywords"></div>
                <div class="credit-row">
                  <p class="credit" id="imageCredit"></p>
                  <p class="flip-cue flip-cue--rev">↺ wróć</p>
                </div>
              </div>
            </div>
          </div>
        </article>
      </div>
      <div class="controls">
        <button class="ctrl-btn" id="prevBtn" disabled><span>←</span> <span class="ctrl-label">Poprzednia</span></button>
        <span class="counter" id="cardCounter">1 / 12</span>
        <button class="ctrl-btn ctrl-btn--r" id="nextBtn"><span class="ctrl-label">Następna</span> <span>→</span></button>
      </div>
    </div>

    <!-- SCIENCE -->
    <div id="scienceView" class="view hidden">
      <div class="deck-meta">
        <span id="sciProgress" class="meta-count"></span>
        <span id="sciCategory" class="meta-cat"></span>
      </div>
      <div class="scene">
        <article class="card" id="sciCard" tabindex="0" role="button" aria-pressed="false">
          <div class="card-inner" id="sciCardInner">
            <div class="face face-front">
              <div class="card-img-wrap">
                <img id="sciImg" class="card-img" src="" alt="" loading="lazy" />
                <span class="cat-badge" id="sciPill"></span>
                <button class="fav-btn" id="sciFavBtn" aria-label="Save to favourites">♡</button>
                <div class="gal-nav" id="sciGalNav">
                  <button class="gal-arrow" id="sciGalPrev" aria-label="Previous image">&#8249;</button>
                  <div class="gal-dots" id="sciGalDots"></div>
                  <button class="gal-arrow" id="sciGalNext" aria-label="Next image">&#8250;</button>
                </div>
              </div>
              <div class="front-body">
                <p class="eyebrow">Wskazówka</p>
                <p class="hint-text" id="sciHint"></p>
                <h2 class="card-title" id="sciTitle"></h2>
                <p class="flip-cue">kliknij, by odkryć →</p>
              </div>
            </div>
            <div class="face face-back">
              <div class="back-top">
                <span class="back-badge" id="sciBackCat"></span>
                <h2 class="back-title" id="sciBackTitle"></h2>
                <p class="back-period" id="sciBackPeriod"></p>
              </div>
              <div class="back-rule"></div>
              <div class="back-body">
                <div class="info-block">
                  <p class="info-label" id="sciFieldLabel">Dziedzina</p>
                  <p class="info-value" id="sciField"></p>
                </div>
                <div class="info-block">
                  <p class="info-label" id="sciDiscLabel">Odkrycia</p>
                  <p class="info-value" id="sciDisc"></p>
                </div>
              </div>
              <div class="back-footer">
                <div class="tag-row" id="sciKeywords"></div>
                <div class="credit-row">
                  <p class="credit" id="sciCredit"></p>
                  <p class="flip-cue flip-cue--rev">↺ wróć</p>
                </div>
              </div>
            </div>
          </div>
        </article>
      </div>
      <div class="controls">
        <button class="ctrl-btn" id="sciPrev" disabled><span>←</span> <span class="ctrl-label">Poprzednia</span></button>
        <span class="counter" id="sciCounter">1 / 30</span>
        <button class="ctrl-btn ctrl-btn--r" id="sciNext"><span class="ctrl-label">Następna</span> <span>→</span></button>
      </div>
    </div>

    <!-- VOCAB -->
    <div id="vocabView" class="view hidden">
      <div class="vocab-meta">
        <span id="vocabCounter" class="meta-count"></span>
        <button id="vocabReshuffle" class="ghost-btn">⇄ <span id="reshuffleLabel">Przetasuj</span></button>
      </div>
      <div class="scene">
        <article class="card vocab-card" id="vocabCard" tabindex="0" role="button" aria-pressed="false">
          <div class="card-inner" id="vocabCardInner">
            <div class="face face-front vocab-face-front">
              <button class="fav-btn fav-btn--vocab" id="vocabFavBtn" aria-label="Save to favourites">♡</button>
              <p class="vocab-badge">PL ↔ EN</p>
              <p class="eyebrow" id="vocabTermLabel">Termin</p>
              <h2 class="vocab-term" id="vocabTermText"></h2>
              <p class="vocab-sub" id="vocabTermSub"></p>
              <p class="flip-cue">kliknij, by odkryć →</p>
            </div>
            <div class="face face-back vocab-face-back">
              <p class="eyebrow" id="vocabDefLabel">Definicja</p>
              <p class="vocab-def" id="vocabDefText"></p>
              <p class="flip-cue flip-cue--rev" style="margin-top:auto">↺ wróć</p>
            </div>
          </div>
        </article>
      </div>
      <div class="controls">
        <button class="ctrl-btn" id="vocabPrev" disabled><span>←</span> <span class="ctrl-label">Poprzedni</span></button>
        <span class="counter" id="vocabCounterNav">· · ·</span>
        <button class="ctrl-btn ctrl-btn--r" id="vocabNext"><span class="ctrl-label">Następny</span> <span>→</span></button>
      </div>
    </div>

    <!-- QUIZ -->
    <div id="quizView" class="view hidden">

      <div id="quizSetup" class="quiz-setup">
        <h2 class="quiz-heading" id="quizSetupTitle">Wybierz kategorie</h2>
        <p class="quiz-sub" id="quizSetupSub">Możesz wybrać jedną lub więcej</p>
        <div class="quiz-grid" id="quizCatGrid"></div>
        <button class="primary-btn" id="quizStartBtn" disabled>Rozpocznij →</button>
      </div>

      <div id="quizActive" class="quiz-active hidden">
        <div class="quiz-bar">
          <div class="quiz-bar-fill" id="qProgressFill"></div>
        </div>
        <div class="quiz-status">
          <span id="qCounter" class="meta-count"></span>
          <span id="qScore" class="quiz-score-live">✓ 0</span>
        </div>
        <div class="quiz-card">
          <p class="cat-badge quiz-cat" id="qCatBadge"></p>
          <h3 class="quiz-q" id="qQuestion"></h3>
          <div class="quiz-opts" id="qOptions"></div>
          <p class="quiz-fb hidden" id="qFeedback"></p>
          <button class="primary-btn quiz-next hidden" id="qNextBtn">Dalej →</button>
        </div>
      </div>

      <div id="quizResult" class="quiz-result hidden">
        <div class="result-card">
          <p class="eyebrow" id="qResultLabel">Twój wynik</p>
          <div class="result-score" id="qResultScore">0 / 0</div>
          <div class="result-pct" id="qResultPct">0%</div>
          <button class="primary-btn" id="quizRestartBtn">Zagraj ponownie</button>
          <button class="ghost-btn" id="quizBackBtn">← Zmień kategorie</button>
        </div>
      </div>

    </div>

  </main>

  <footer class="footer">
    <span><kbd>Space</kbd> <span id="footerFlip">flip</span></span>
    <span class="footer-dot">·</span>
    <span><kbd>←</kbd><kbd>→</kbd> <span id="footerNav">navigate</span></span>
  </footer>

  <script src="/artsy/script.js" is:inline></script>
</body>
</html>
